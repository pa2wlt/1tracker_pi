<?xml version="1.0" encoding="utf-8"?>
<!--
  Initial catalog metadata skeleton generated by CMake.
  Keep this aligned with the generated plugin metadata header so the plugin
  manager strings and catalog text come from the same source.
-->
<plugin version="1">
  <name>@ONETRACKER_PLUGIN_COMMON_NAME@</name>
  <package>@ONETRACKER_PLUGIN_PACKAGE_NAME@</package>
  <version>@PROJECT_VERSION@</version>
  <summary>@ONETRACKER_PLUGIN_SUMMARY@</summary>
  <description>@ONETRACKER_PLUGIN_DESCRIPTION@</description>
  <source>@ONETRACKER_PLUGIN_SOURCE_URL@</source>
  <license>@ONETRACKER_PLUGIN_LICENSE@</license>
</plugin>
