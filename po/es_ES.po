#: src/endpoint_error_summary.cpp:27
msgid "The authorization token is invalid or expired."
msgstr "El token de autorización inválido o ha caducado."

#: src/endpoint_error_summary.cpp:28
msgid "The server name could not be resolved."
msgstr "No se pudo resolver el nombre del servidor."

#: src/endpoint_error_summary.cpp:29 src/endpoint_error_summary.cpp:30
msgid "Could not connect to the server."
msgstr "No se pudo conectar al servidor."

#: src/endpoint_error_summary.cpp:31
msgid "The server took too long to respond."
msgstr "El servidor tardó demasiado en responder."

#: src/endpoint_error_summary.cpp:32
msgid "The server rejected the credentials."
msgstr "El servidor rechazó las credenciales."

#: src/endpoint_error_summary.cpp:33
msgid "The server refused this request."
msgstr "El servidor rechazó esta solicitud."

#: src/endpoint_error_summary.cpp:34
msgid "The tracking URL could not be found."
msgstr "No se pudo encontrar la URL de seguimiento."

#: src/endpoint_error_summary.cpp:35
msgid "The server responded, but rejected the tracking data."
msgstr "El servidor respondió, pero rechazó los datos de seguimiento."

#: src/endpoint_error_summary.cpp:42
msgid "Your NFL boat key is missing or invalid."
msgstr "Su llave de barco NFL falta o no es válida."

#: src/endpoint_error_summary.cpp:44
msgid "The API key was not accepted by the server."
msgstr "El servidor no aceptó la clave API."

#: src/endpoint_error_summary.cpp:46
msgid "The server returned an error while processing the tracking request."
msgstr "El servidor devolvió un error al procesar la solicitud de seguimiento."

#: src/endpoint_error_summary.cpp:48
msgid "Tracking could not be sent. Check the technical details below."
msgstr "No se pudo enviar seguimiento. Compruebe detalles técnicos a continuación."

